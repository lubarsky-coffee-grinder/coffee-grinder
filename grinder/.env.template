# OpenAI
# Template values below are tuned for cheaper test/prod trial runs.
# If a variable is empty, code-level defaults from src/* are used.
OPENAI_API_KEY=
OPENAI_SUMMARIZE_MODEL=gpt-5-mini
OPENAI_FACTS_MODEL=gpt-4o
# Arguments flow uses the Responses API with file_search + web_search.
# gpt-5-mini is kept here intentionally as a cheaper compatible model for tests.
OPENAI_ARGUMENTS_MODEL=gpt-5-mini
OPENAI_TITLE_LOOKUP_MODEL=gpt-4o
OPENAI_VIDEO_VERIFY_MODEL=gpt-4o-mini
OPENAI_VIDEO_WEBSEARCH_MODEL=gpt-4o-mini
OPENAI_FALLBACK_KEYWORDS_MODEL=gpt-4.1-mini
OPENAI_SCREENSHOT_MODEL=gpt-4o-mini
OPENAI_WEBSEARCH_CONTEXT_SIZE=low

# newsapi.ai (EventRegistry)
NEWS_API_KEY=
# Optional (ms). Default: 10000.
NEWS_API_TIMEOUT_MS=

# Optional. Set to 1 only when YouTube OAuth is configured and working.
YOUTUBE_API_ENABLED=
# YouTube Data API scan depth per trusted source (100..200). Code default: 150.
YOUTUBE_UPLOADS_PER_SOURCE=
# Max videos per trusted YouTube source sent to GPT verification.
# Code default: 4. Template override below is intentionally lower for faster/cheaper runs.
YOUTUBE_VERIFY_VIDEOS_PER_SOURCE=2
# Global cap of YouTube videos per story sent to GPT verification.
# Code default: 18. Template override below is intentionally lower for faster/cheaper runs.
YOUTUBE_VERIFY_VIDEOS_PER_STORY=8
# Number of keyword search queries for YouTube API search.list.
# Code default: 3. Template override below is intentionally lower for faster/cheaper runs.
YOUTUBE_SEARCH_QUERIES=2
# Max results per one YouTube keyword query.
# Code default: 12. Template override below is intentionally lower for faster/cheaper runs.
YOUTUBE_SEARCH_RESULTS_PER_QUERY=6
# If 1, run open YouTube keyword fallback (without allow-list, excluding Al Jazeera). Default: 1.
YOUTUBE_OPEN_FALLBACK=1
# If 1, enable OpenAI web_search fallback for video lookup when YouTube stages return nothing. Default: 1.
VIDEO_GPT_WEBSEARCH=1
# Max candidate URLs requested/processed in GPT web_search fallback. Default: 8.
VIDEO_GPT_WEBSEARCH_MAX_CANDIDATES=8

# E2E summarize (used by `npm run test:e2e` via `.env.e2e`)
